# ========================
# LLM credentials
# ========================
GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/

KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

ANTHROPIC_API_KEY=

# ========================
# LLM tier selection
# ========================
LLM_RAPID_PROVIDER=glm
LLM_RAPID_MODEL=glm-4.7-flash
LLM_STANDARD_PROVIDER=glm
LLM_STANDARD_MODEL=glm-4.7
LLM_REASONING_PROVIDER=glm
LLM_REASONING_MODEL=glm-4.7

# ========================
# Sandbox MCP connection
# ========================
# Default command starts local package server:
# uv run python -m sandbox_mcp_server
SANDBOX_MCP_SERVER_COMMAND=uv
SANDBOX_MCP_SERVER_ARGS=run,python,-m,sandbox_mcp_server
SANDBOX_MCP_SERVER_CWD=
SANDBOX_MCP_TIMEOUT_BUFFER_SECONDS=30

# Docker image used by sandbox_mcp_server internal executor
SANDBOX_IMAGE=build123d-runtime:latest
SANDBOX_MEMORY_LIMIT=512m
SANDBOX_CPU_QUOTA=100000

# Optional
LLM_TIMEOUT_SECONDS=60
SUB_AGENT_ACI_MAX_ITERATIONS=12
